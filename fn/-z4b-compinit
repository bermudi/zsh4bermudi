# -z4b-compinit - Initialize completion system with dump caching
# Runs compinit with a persistent dump file for fast subsequent loads.
# Resilient to errexit: every potentially-failing command is guarded.

local dump_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh4bermudi"
local dump_file="$dump_dir/zcompdump"
mkdir -p "$dump_dir"

autoload -Uz compinit
compinit -d "$dump_file" 2>/dev/null || compinit 2>/dev/null || true

# Wire up bash completions for installed tools
autoload -Uz bashcompinit 2>/dev/null && bashcompinit 2>/dev/null || true
local tool
for tool in cargo gh kubectl helm terraform vault gcloud aws; do
  command -v "$tool" >/dev/null 2>&1 || continue
  [[ -f "/usr/share/bash-completion/completions/$tool" ]] || continue
  source "/usr/share/bash-completion/completions/$tool" 2>/dev/null || true
done

return 0
