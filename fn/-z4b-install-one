#!/usr/bin/env zsh
# fn/-z4b-install-one
# Clone a single GitHub repo to $Z4B_ROOT/owner/repo/

local repo=$1
if [[ -z "$repo" || "$repo" != */* ]]; then
  print -u2 "z4b: invalid repository format. Expected 'owner/repo'."
  return 1
fi

local dst="$Z4B_ROOT/$repo"
local url="https://github.com/${repo}.git"

print "z4b: installing ${repo}"

if [[ -d "$dst" ]]; then
  print "z4b: ${repo} is already installed. Updating..."
  (cd "$dst" && git pull --rebase --autostash) || return 1
else
  mkdir -p -- "${dst:h}" || return 1
  git clone --depth 1 -- "$url" "$dst" || return 1
fi

print "z4b: ${repo} installed successfully."
