#!/usr/bin/env zunit

@test 'z4b init completes within 2 seconds' {
  unset _z4b_bootstrapped _z4b_initialized
  source "$Z4B_ROOT/z4b.zsh"

  zmodload zsh/datetime 2>/dev/null
  local start=$EPOCHREALTIME
  run z4b init
  local elapsed=$(( EPOCHREALTIME - start ))

  assert $state equals 0
  # Should be well under 2s even on slow CI runners; a 28ms target
  # would be flaky, so we gate on a coarse ceiling.
  (( elapsed < 2.0 ))
  assert $state equals 0
}

@test 'compinit dump file is created after z4b init' {
  unset _z4b_bootstrapped _z4b_initialized
  source "$Z4B_ROOT/z4b.zsh"
  run z4b init
  assert $state equals 0

  local dump_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh4bermudi"
  local dump_file="$dump_dir/zcompdump"
  mkdir -p "$dump_dir"

  # DIAG: non-blocking compinit probes (stdin from /dev/null) to capture the
  # insecure-directory prompt that blocks/aborts on the runner.
  autoload -Uz compinit
  compinit -d "$dump_file.plain" 2>/tmp/ci.err </dev/null; local rc1=$?
  print -r -- "DIAG plain: rc=$rc1 stderr=[$(</tmp/ci.err)] file=$([[ -f $dump_file.plain ]] && echo YES || echo no)"

  compinit -u -d "$dump_file.skip" 2>/tmp/ci2.err </dev/null; local rc2=$?
  print -r -- "DIAG -u:     rc=$rc2 stderr=[$(</tmp/ci2.err)] file=$([[ -f $dump_file.skip ]] && echo YES || echo no)"

  compinit -i -d "$dump_file.ign" 2>/tmp/ci3.err </dev/null; local rc3=$?
  print -r -- "DIAG -i:     rc=$rc3 stderr=[$(</tmp/ci3.err)] file=$([[ -f $dump_file.ign ]] && echo YES || echo no)"

  print -r -- "DIAG fpath: ${(qq)fpath}"

  [[ -f "$dump_file" ]]
  assert $state equals 0
}

@test 'z4b.zsh bootstrap is idempotent' {
  unset _z4b_bootstrapped _z4b_initialized
  source "$Z4B_ROOT/z4b.zsh"
  run z4b init
  assert $state equals 0

  local fn_count_before=0
  local p
  for p in $fpath; do
    [[ "$p" == "$Z4B_ROOT/fn" ]] && (( fn_count_before++ ))
  done

  source "$Z4B_ROOT/z4b.zsh"
  run z4b init
  assert $state equals 0

  local fn_count_after=0
  for p in $fpath; do
    [[ "$p" == "$Z4B_ROOT/fn" ]] && (( fn_count_after++ ))
  done

  assert $fn_count_after equals $fn_count_before
}
